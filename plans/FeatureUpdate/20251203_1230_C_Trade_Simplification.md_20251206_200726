# From api.py
def fetch_recent_snapshots(self, session_id: str, lookback: int) -> pd.DataFrame:
    """
    Fetches recent closed trade snapshots filtered by session.
    
    Parameters:
        session_id: Current session GUID
        lookback: Number of recent closed trades to fetch
    
    Returns:
        DataFrame with columns: timestamp, alt_pnl, product, trade_type, etc.
    """
    endpoint = ENDPOINT_TBL105_LIFECYCLE_SIM if self.is_simulation_mode else ENDPOINT_TBL105_LIFECYCLE
    params = {
        'session_id': session_id,
        'event_type': 'close',
        'limit': lookback,
        'ordering': '-timestamp'  # Most recent first
    }
    return self._fetch_data_from_url(endpoint, **params)
